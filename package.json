{
  "name": "@vinniai/claude-profiles",
  "version": "3.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Manage isolated Claude Code and Codex profiles, route tasks across accounts, and fail over on limit/auth/server errors",
  "author": "Vinniai",
  "contributors": [
    "Mike Veerman (original jean-claude author)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Vinniai/claude-profiles"
  },
  "homepage": "https://github.com/Vinniai/claude-profiles#readme",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "claude-profiles": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "./test-integration.sh",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "openai",
    "mcp",
    "dotfiles",
    "sync",
    "cli",
    "configuration"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "templates",
    "scripts"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
